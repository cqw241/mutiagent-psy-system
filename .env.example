APP_NAME=面向高校学生心理风险早期识别与转介辅助的多智能体协同系统
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# 模型层默认通过 LiteLLM 访问 OpenAI-compatible 接口。
# 当前先接阿里云百炼，后续可替换为本地模型服务地址。
LLM_PROVIDER=litellm
LLM_MODEL=openai/qwen3.5-plus
LLM_API_KEY=your-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=30

# 本地联调可指向 mock webhook，后续替换成校内告警系统。
COUNSELOR_ALERT_WEBHOOK=http://localhost:8080/mock-webhook
RAGFLOW_BASE_URL=http://127.0.0.1
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_DATASET_ID=your-ragflow-dataset-id
RAGFLOW_TIMEOUT_SECONDS=10
ENABLE_RAG=false

# LangGraph checkpoint backend
# development/test 推荐 memory；单机试点可切到 file；更高阶环境预留 postgres/redis。
CHECKPOINT_BACKEND=memory
CHECKPOINT_DIR=.langgraph-checkpoints
CHECKPOINT_POSTGRES_URL=
CHECKPOINT_REDIS_URL=

# 可选：emotion2vec 深度语音情感识别增强信号
# 默认开启；设为 false 时 voice_analyzer 会保持旧链路不变，并返回 emotion2vec_reading.status=disabled
ENABLE_EMOTION2VEC=true
EMOTION2VEC_MODEL_DIR=
EMOTION2VEC_SAMPLE_RATE=16000
