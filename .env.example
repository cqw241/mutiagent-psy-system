APP_NAME=面向高校学生心理风险早期识别与转介辅助的多智能体协同系统
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# 模型层默认通过 LiteLLM 访问 OpenAI-compatible 接口。
# 当前先接阿里云百炼，后续可替换为本地模型服务地址。
LLM_PROVIDER=litellm
LLM_MODEL=openai/qwen3.5-plus
LLM_API_KEY=your-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=30

# TTS 默认走阿里云百炼 qwen-tts-latest。
# 未单独配置 TTS_API_KEY 时，会回退复用 BAILIAN_API_KEY / LLM_API_KEY。
TTS_ENABLED=true
TTS_PROVIDER=dashscope
TTS_API_KEY=your-bailian-api-key
TTS_MODEL=qwen-tts-latest
TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
TTS_TIMEOUT_SECONDS=60
TTS_QWEN_VOICE=Serena
TTS_QWEN_LANGUAGE_TYPE=Chinese

# 本地联调可指向 mock webhook；这只验证投递调用，不代表真实告警闭环。
# 校内试点前应替换成真实告警系统，并补齐事件持久化、人工接单和回执。
COUNSELOR_ALERT_WEBHOOK=http://localhost:8080/mock-webhook
RAGFLOW_BASE_URL=http://127.0.0.1
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_DATASET_ID=your-ragflow-dataset-id
RAGFLOW_TIMEOUT_SECONDS=10
ENABLE_RAG=false

# LangGraph checkpoint backend
# development/test 推荐 memory；单机试点可切到 file。
# postgres/redis 当前仅为接口预留，仓库尚未内置对应 saver 依赖与生产配置。
CHECKPOINT_BACKEND=memory
CHECKPOINT_DIR=.langgraph-checkpoints
CHECKPOINT_POSTGRES_URL=
CHECKPOINT_REDIS_URL=

# 数据保存基线见 README 与白皮书：允许保存完整对话文本和 ASR 转写用于审计复盘；
# 默认不保存原始视频，原始音频默认不长期保存，仅保留声学特征、转写和必要 trace。

# 可选：emotion2vec 深度语音情感识别增强信号
# 默认开启；设为 false 时 voice_analyzer 会保持旧链路不变，并返回 emotion2vec_reading.status=disabled
ENABLE_EMOTION2VEC=true
EMOTION2VEC_MODEL_DIR=
EMOTION2VEC_SAMPLE_RATE=16000
